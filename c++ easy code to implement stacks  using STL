#include <iostream>
#include <stack> 
using namesapce std;
int main() 
{
    stack<int> s;
    s.push(10);
    s.push(20);
    s.push(30);
    cout << "Top element: " << s.top() << endl; 
    s.pop(); 
    cout << "New top after pop: " << s.top() << endl; 
    cout << "Stack size: " << s.size() << endl;
    if (!s.empty())
    {
        cout << "Stack is not empty!" <<endl;
    }
    return 0;
}
