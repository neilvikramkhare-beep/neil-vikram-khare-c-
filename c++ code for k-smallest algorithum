#include <iostream>
using namespace std;
int kthSmallest(int a[], int n, int k) {
    int maxElement = a[0];
    for (int i = 1; i < n; i++) {
        if (a[i] > maxElement) {
            maxElement = a[i];
        }
    }
    int freq[maxElement + 1] = {0};
    for (int i = 0; i < n; i++) {
        freq[a[i]]++;
    }
    int count = 0;
    for (int i = 0; i <= maxElement; i++) {
        if (freq[i] != 0) {
            count += freq[i];
            if (count >= k) {
                return i;
            }
        }
    }
    return -1;
}
int main() {
    int a[] = {12,3,5,7,19};
    int n = sizeof(a) / sizeof(a[0]);
    int k = 2;
    cout << "The " << k << "th smallest element is " << kthSmallest(a, n, k) << endl;
    return 0;
}
