#include <iostream>
#include <vector>
using namespace std;
int main() {
    int arr[] = {0, -1, 2, -3, 1};
    int n = sizeof(arr) / sizeof(arr[0]);
    bool found = false;
    cout << "Triplets with sum 0 are:" << endl;
    for (int i = 0; i < n - 2; i++) {
        for (int j = i + 1; j < n - 1; j++) {
            for (int k = j + 1; k < n; k++) {
                if (arr[i] + arr[j] + arr[k] == 0) {
                    cout << arr[i] << ", " << arr[j] << ", " << arr[k] << endl;
                    found = true;
                }
            }
        }
    }
    if (!found) {
        cout << "No triplets found." << endl;
    }
    return 0;
}
