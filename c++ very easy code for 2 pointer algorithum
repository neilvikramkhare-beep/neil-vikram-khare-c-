#include <iostream>
#include <vector>
#include <algorithm> 
using namespace std;
bool hasPairWithSum(vector<int>& a, int target) 
{
    int left = 0;
    int right = a.size() - 1;
    while (left < right) 
    {
        int currentSum = a[left] + a[right];
        if (currentSum == target) 
        {
      cout <<"Pair found: "<<a[left] << " + " << a[right] << endl;
            return true;
        } 
        else if (currentSum < target) 
        {
            left++;
        } 
        else 
        {
            right--;
        }
    }
    return false; 
}
int main()
{
    vector<int> numbers = {1, 3, 5, 8, 10, 15};
    int target = 13;
    if (!hasPairWithSum(numbers, target)) 
    {
        cout << "No pair with that sum exists." << endl;
    }
    return 0;
}
