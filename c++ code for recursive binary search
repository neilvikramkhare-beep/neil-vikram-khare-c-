#include <iostream>
#include <vector>
using namespace std;
int binarySearch(const vector<int>& arr, int low, int high, int target) {
    if (low > high) {
        return -1;
    }
    int mid = low + (high - low) / 2;
    if (arr[mid] == target) {
        return mid;
    }
    if (target < arr[mid]) {
        return binarySearch(arr, low, mid - 1, target);
    }
    return binarySearch(arr, mid + 1, high, target);
}
int main()
{
    vector<int> data = {2, 5, 8, 12, 16, 23, 38, 56, 72, 91};
    int target = 23;
    int result = binarySearch(data, 0, data.size() - 1, target);
    if (result != -1)
     cout << "Element found at index: " << result <<endl;
    else
     cout << "Element not found." <<endl;
    return 0;
}
