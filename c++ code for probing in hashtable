#include <iostream>
using namespace std;
const int SIZE = 10;
class HashTable {
private:
    int keys[SIZE];
    string values[SIZE];
    bool used[SIZE];
public:
    HashTable() {
        for (int i = 0; i < SIZE; i++) {
            used[i] = false;
        }
    }
    int hash(int key) {
        return key % SIZE;
    }
    void insert(int key, string value) {
        int index = hash(key);
        while (used[index] && keys[index] != key) {
            index = (index + 1) % SIZE;
        }
        keys[index] = key;
        values[index] = value;
        used[index] = true;
        cout << "Inserted {" << key << ": " << value 
             << "} at index " << index << endl;
    }
    string search(int key) {
        int index = hash(key);
        int start = index;
        while (used[index]) {
            if (keys[index] == key)
                return values[index];
            index = (index + 1) % SIZE;
            if (index == start)
                break; 
        }
        return "Not Found";
    }
    void display() {
        cout <<"Hash Table:\n";
        for (int i = 0; i < SIZE; i++) {
            cout << "Index " << i << ": ";
            if (used[i])
                cout << "{" << keys[i] << ": " << values[i] << "}";
            else
                cout << "[Empty]";
            cout << endl;
        }
    }
};
int main()
{
    HashTable h;
    h.insert(10, "Apple");
    h.insert(0, "Banana");
    h.insert(20, "Cherry");
    h.insert(1, "Date");
    h.display();
    cout << "\nSearching for key 20: " << h.search(20) << endl;
    cout << "Searching for key 5: " << h.search(5) << endl;
    return 0;
}
