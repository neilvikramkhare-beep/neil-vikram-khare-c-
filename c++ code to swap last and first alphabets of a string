#include <iostream>
#include <string>
#include <algorithm> 
using namespace std;
int main() 
{
    string str;
    cout << "Enter a string: ";
    cin >> str;
    if (str.length() > 1) 
    {
        swap(str[0], str[str.length() - 1]);
    }
    cout << "Modified string: " << str << endl;
    return 0;
}
