#include <iostream>
#include <vector>
using namespace std;
void findIntersection(int a1[], int n1, int a2[], int n2)
{
    int i = 0, j = 0;
    cout << "Intersection: ";
    while (i < n1 && j < n2) 
    {
        if (a1[i] < a2[j])
        {
            i++; 
        } 
        else if (a2[j] < a1[i]) 
        {
            j++; 
        } 
        else 
        {
            cout << a1[i] << " ";
            i++;
            j++;
        }
    }
}
int main()
{
    int a1[] = {1, 2, 4, 5, 6};
    int a2[] = {2, 3, 5, 7};
    int n1 = sizeof(a1) / sizeof(a1[0]);
    int n2 = sizeof(a2) / sizeof(a2[0]);
    findIntersection(a1, n1, a2, n2);
    return 0;
}
